# ─── App ────────────────────────────────────────────────────────────────────
APP_NAME=HireHub
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=hirehub
POSTGRES_PASSWORD=hirehub_secret
POSTGRES_DB=hirehub_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://hirehub:hirehub_secret@postgres:5432/hirehub_db
DATABASE_URL_SYNC=postgresql://hirehub:hirehub_secret@postgres:5432/hirehub_db

# ─── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ─── OAuth ───────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── Google Calendar ─────────────────────────────────────────────────────────
GOOGLE_CALENDAR_CREDENTIALS_JSON={}

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Email (SendGrid) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-key-here
EMAIL_FROM=noreply@hirehub.io
EMAIL_FROM_NAME=HireHub

# ─── Slack ───────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# ─── Twilio (SMS / WhatsApp) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Storage (S3-compatible for resumes/logos) ───────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=hirehub-uploads
S3_ENDPOINT_URL=

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-nextauth-secret
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Super Admin ─────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@hirehub.io
